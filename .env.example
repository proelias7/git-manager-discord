# ============================================
# Configuração do Bot Discord
# ============================================

# Token do bot do Discord (obrigatório)
# Obtenha em: https://discord.com/developers/applications
BOT_TOKEN=seu_token_aqui

# ID do cliente da aplicação Discord (obrigatório)
CLIENT_ID=seu_client_id_aqui

# ID do servidor Discord (opcional, mas recomendado para testes)
# Se não definido, os comandos serão registrados globalmente
GUILD_ID=id_do_servidor_aqui

# ============================================
# Configuração do Git
# ============================================

# Caminho base onde estão localizados os repositórios Git (obrigatório)
# Este diretório será usado para:
# - Comandos do bot Discord
# - Auto-mapping de repositórios para webhooks
# Exemplo Windows: C:/Users/Usuario/projetos
# Exemplo Linux/Mac: /home/usuario/projetos
GIT_BASE_PATH=caminho/para/seus/repositorios

# ============================================
# Permissões Discord (ações Git no painel)
# ============================================
# ID do cargo no servidor: quem tiver este cargo tem acesso a todas as ações Git em todos os repositórios
# e pode abrir o botão "Gerir acessos" no painel para adicionar/remover utilizadores por repositório
# (lista persistida em data/repoUserAccess.json).
# Quem não tem este cargo só pode usar pull/commit/etc. nos repositórios em que o seu user ID foi autorizado.
# Se deixar vazio: ninguém é "admin Git" por cargo; nesse caso só quem tem permissão Administrador no Discord
# é tratado como admin para efeitos de bootstrap (ex.: /init quando ainda não há utilizadores no principal).
GIT_ADMIN_ROLE_ID=

# ============================================
# Configuração do Webhook (GitHub/GitLab)
# ============================================

# Habilitar serviço de webhook (true/false)
# Quando habilitado, o bot receberá webhooks do GitHub/GitLab e executará
# pull automático quando um commit contiver "@pull" na mensagem
ENABLE_GITHUB_WEBHOOK=false

# Porta onde o servidor de webhook será executado (padrão: 3001)
WEBHOOK_PORT=3001

# Secret do webhook (opcional mas recomendado para segurança)
# Use o MESMO secret tanto no GitHub quanto no GitLab
# Gere um secret seguro em: https://www.random.org/strings/
WEBHOOK_SECRET=

# ID do canal do Discord para receber notificações de pull automático (opcional)
# Se não definido, não serão enviadas notificações no Discord
DISCORD_WEBHOOK_CHANNEL_ID=

# Habilitar mapeamento automático de repositórios (true/false)
# Quando habilitado, o sistema procura automaticamente por repositórios
# (incluindo submódulos) no GIT_BASE_PATH baseado no nome do repo recebido no webhook
AUTO_REPO_MAPPING=true

# ============================================
# Configuração de Deploy de Comandos
# ============================================

# Habilitar deploy automático dos comandos ao iniciar (true/false)
# Se não definido ou true, os comandos serão registrados automaticamente
# Defina como false se preferir fazer deploy manual com: node src/deploy-commands.js
AUTO_DEPLOY_COMMANDS=true

# ============================================
# Pull antes do reinício (node-cron, relógio local do servidor)
# ============================================

# Desligar o agendador sem apagar RESTART_SCHEDULE (true/false)
# Se não definido ou true, o agendador inicia quando RESTART_SCHEDULE tiver valores
RESTART_SCHEDULE_ENABLED=true
# Horários de REINÍCIO do servidor (os mesmos do txAdmin), separados por vírgula, formato 24h.
# O bot executa git pull N minutos ANTES de cada horário (submódulos enfileirados + paths em data/repoPolicy.json).
# Exemplo: reinício às 03:00 e às 15:00 → RESTART_SCHEDULE=03:00,15:00
RESTART_SCHEDULE=

# Minutos antes do reinício para executar os pulls agendados (padrão: 2)
RESTART_PULL_LEAD_MINUTES=2
